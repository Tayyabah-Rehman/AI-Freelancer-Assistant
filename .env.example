# Rename this file to .env before running the app

# Flask
SECRET_KEY=change-this-to-a-random-secret-string
FLASK_ENV=development

# Database (SQLite file lives inside /instance, created automatically)
DATABASE_URL=sqlite:///app.db

# AI Provider (used starting Day 2 - Proposal & Cover Letter Module)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
